# ─── SpellRightPro API — Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your real values.
# NEVER commit .env to GitHub. Add it to .gitignore.

# ── Email (Gmail) ─────────────────────────────────────────────────────────────
# The Gmail address that sends welcome and confirmation emails.
EMAIL_USER=spellrightpro@gmail.com

# A Gmail App Password (NOT your main Gmail password).
# Generate one at: https://myaccount.google.com/apppasswords
# Required: server will refuse to start without this.
EMAIL_PASSWORD=your_gmail_app_password_here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3801
NODE_ENV=production

# ── Stripe (for future webhook handling) ─────────────────────────────────────
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ── Firebase Admin (for updating Firestore after payment) ─────────────────────
# FIREBASE_PROJECT_ID=spellrightpro-firebase
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk@...
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
