# .gitignore - Prevent sensitive files from being committed

# Environment variables
.env
.env.local
.env.production

# Node modules
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
build/
out/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
logs/
*.log

# Firebase
firebase-debug.log
.firebase/

# Netlify
.netlify/

# Local development
.spellrightpro-local
*.local

# Sensitive files
*.pem
*.key
*.cert
secrets/

# Backup files
*.bak
*.backup

# Database
*.db
*.sqlite

# Coverage
coverage/

# Temporary files
tmp/
temp/
